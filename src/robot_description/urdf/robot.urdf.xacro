<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="skid_steer_robot">

  <!-- ==================== Configurable Properties ==================== -->
  <xacro:property name="wheel_radius"   value="0.033"/>
  <xacro:property name="wheel_width"    value="0.026"/>
  <xacro:property name="track_width"    value="0.23"/>
  <xacro:property name="wheelbase"      value="0.16"/>
  <xacro:property name="chassis_length" value="0.26"/>
  <xacro:property name="chassis_width"  value="0.20"/>
  <xacro:property name="chassis_height" value="0.08"/>
  <xacro:property name="chassis_mass"   value="2.0"/>
  <xacro:property name="wheel_mass"     value="0.15"/>

  <!-- Laser mount: on top of chassis center -->
  <xacro:property name="laser_x"  value="0.0"/>
  <xacro:property name="laser_y"  value="0.0"/>
  <xacro:property name="laser_z"  value="${chassis_height / 2.0 + 0.02}"/>

  <!-- IMU mount: at center of base_link -->
  <xacro:property name="imu_x" value="0.0"/>
  <xacro:property name="imu_y" value="0.0"/>
  <xacro:property name="imu_z" value="0.0"/>

  <!-- ==================== Inertia Macros ==================== -->
  <xacro:macro name="box_inertia" params="m x y z">
    <inertial>
      <mass value="${m}"/>
      <inertia ixx="${m*(y*y+z*z)/12.0}" ixy="0" ixz="0"
               iyy="${m*(x*x+z*z)/12.0}" iyz="0"
               izz="${m*(x*x+y*y)/12.0}"/>
    </inertial>
  </xacro:macro>

  <xacro:macro name="cylinder_inertia" params="m r h">
    <inertial>
      <mass value="${m}"/>
      <inertia ixx="${m*(3.0*r*r+h*h)/12.0}" ixy="0" ixz="0"
               iyy="${m*(3.0*r*r+h*h)/12.0}" iyz="0"
               izz="${m*r*r/2.0}"/>
    </inertial>
  </xacro:macro>

  <!-- ==================== Wheel Macro ==================== -->
  <xacro:macro name="wheel" params="name x_offset y_offset">
    <link name="${name}_wheel">
      <visual>
        <geometry>
          <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
        </geometry>
        <material name="dark_grey">
          <color rgba="0.3 0.3 0.3 1.0"/>
        </material>
      </visual>
      <collision>
        <geometry>
          <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
        </geometry>
      </collision>
      <xacro:cylinder_inertia m="${wheel_mass}" r="${wheel_radius}" h="${wheel_width}"/>
    </link>

    <joint name="${name}_wheel_joint" type="continuous">
      <parent link="base_link"/>
      <child  link="${name}_wheel"/>
      <origin xyz="${x_offset} ${y_offset} 0.0" rpy="${-pi/2.0} 0 0"/>
      <axis xyz="0 0 1"/>
    </joint>
  </xacro:macro>

  <!-- ==================== Base Link ==================== -->
  <link name="base_footprint"/>

  <link name="base_link">
    <visual>
      <origin xyz="0 0 ${chassis_height / 2.0}" rpy="0 0 0"/>
      <geometry>
        <box size="${chassis_length} ${chassis_width} ${chassis_height}"/>
      </geometry>
      <material name="blue">
        <color rgba="0.2 0.2 0.8 1.0"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 ${chassis_height / 2.0}" rpy="0 0 0"/>
      <geometry>
        <box size="${chassis_length} ${chassis_width} ${chassis_height}"/>
      </geometry>
    </collision>
    <xacro:box_inertia m="${chassis_mass}" x="${chassis_length}" y="${chassis_width}" z="${chassis_height}"/>
  </link>

  <joint name="base_footprint_joint" type="fixed">
    <parent link="base_footprint"/>
    <child  link="base_link"/>
    <origin xyz="0 0 ${wheel_radius}" rpy="0 0 0"/>
  </joint>

  <!-- ==================== Wheels ==================== -->
  <xacro:wheel name="front_left"  x_offset="${wheelbase/2.0}"  y_offset="${track_width/2.0}"/>
  <xacro:wheel name="front_right" x_offset="${wheelbase/2.0}"  y_offset="${-track_width/2.0}"/>
  <xacro:wheel name="rear_left"   x_offset="${-wheelbase/2.0}" y_offset="${track_width/2.0}"/>
  <xacro:wheel name="rear_right"  x_offset="${-wheelbase/2.0}" y_offset="${-track_width/2.0}"/>

  <!-- ==================== IMU Link ==================== -->
  <link name="imu_link">
    <visual>
      <geometry>
        <box size="0.02 0.02 0.005"/>
      </geometry>
      <material name="green">
        <color rgba="0.0 0.8 0.0 1.0"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <box size="0.02 0.02 0.005"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.01"/>
      <inertia ixx="1e-6" ixy="0" ixz="0" iyy="1e-6" iyz="0" izz="1e-6"/>
    </inertial>
  </link>

  <joint name="imu_joint" type="fixed">
    <parent link="base_link"/>
    <child  link="imu_link"/>
    <origin xyz="${imu_x} ${imu_y} ${imu_z}" rpy="0 0 0"/>
  </joint>

  <!-- ==================== Laser Link (RPLIDAR A1) ==================== -->
  <link name="laser">
    <visual>
      <geometry>
        <cylinder radius="0.035" length="0.020"/>
      </geometry>
      <material name="red">
        <color rgba="0.8 0.0 0.0 1.0"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.035" length="0.020"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.17"/>
      <inertia ixx="1e-5" ixy="0" ixz="0" iyy="1e-5" iyz="0" izz="1e-5"/>
    </inertial>
  </link>

  <joint name="laser_joint" type="fixed">
    <parent link="base_link"/>
    <child  link="laser"/>
    <origin xyz="${laser_x} ${laser_y} ${laser_z}" rpy="0 0 0"/>
  </joint>

</robot>
